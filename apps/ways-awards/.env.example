# Supabase – by default data (projects, categories) loads from Supabase. No local API needed.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Edition year for projects/categories (default 2025)
NEXT_PUBLIC_EDITION=2025

# Optional: only if you use the Nest API for voting or as data source (default port 3003)
# NEXT_PUBLIC_API_URL=http://localhost:3003

# Webflow CMS (jury collection)
# Token must include `cms:read` scope.
# WEBFLOW_CMS_API_TOKEN=your_webflow_token_with_cms_read

# Optional fallback token used by existing devlink helper scripts.
# WEBFLOW_SITE_API_TOKEN=your_webflow_site_api_token
# WEBFLOW_SITE_ID=your_webflow_site_id

{
  "name": "@waysconf/api",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,test}/**/*.ts\" --fix",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist",
    "db:up": "docker compose up -d db",
    "migration:run": "nest build && node -r tsconfig-paths/register ./node_modules/typeorm/cli.js migration:run -d dist/infrastructure/database/data-source.js",
    "migration:generate": "nest build && node -r tsconfig-paths/register ./node_modules/typeorm/cli.js migration:generate -d dist/infrastructure/database/data-source.js",
    "import:json": "node scripts/import-waysawards-json.mjs",
    "restore:downloads": "node scripts/restore-from-downloads.mjs"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.7",
    "@nestjs/core": "^10.4.7",
    "@nestjs/platform-express": "^10.4.7",
    "@nestjs/typeorm": "^10.0.2",
    "@waysconf/shared": "workspace:*",
    "dotenv": "^16.4.5",
    "pg": "^8.13.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.20",
    "postgres": "^3.4.4"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.9",
    "@nestjs/schematics": "^10.2.3",
    "@types/express": "^5.0.0",
    "@types/node": "^22.9.0",
    "@typescript-eslint/eslint-plugin": "^8.15.0",
    "@typescript-eslint/parser": "^8.15.0",
    "eslint": "^9.15.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.6.3"
  }
}